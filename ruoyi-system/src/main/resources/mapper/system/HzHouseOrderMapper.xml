<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.HzHouseOrderMapper">

    <select id="selectExpiredOrders" resultType="com.ruoyi.system.domain.HzHouseOrder">
        SELECT * FROM hz_house_order
        WHERE order_status IN ('0', '1')
          AND lock_expire_time &lt; NOW()
          AND del_flag = '0'
    </select>

</mapper>
