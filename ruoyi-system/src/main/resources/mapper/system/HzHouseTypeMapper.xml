<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.HzHouseTypeMapper">

    <resultMap type="com.ruoyi.system.domain.HzHouseType" id="HzHouseTypeResult">
        <id     property="houseTypeId"      column="house_type_id"    />
        <result property="projectId"        column="project_id"       />
        <result property="projectName"      column="project_name"     />
        <result property="houseTypeName"    column="house_type_name"  />
        <result property="houseTypeCode"    column="house_type_code"  />
        <result property="bedroomCount"     column="bedroom_count"    />
        <result property="livingroomCount"  column="livingroom_count" />
        <result property="bathroomCount"    column="bathroom_count"   />
        <result property="kitchenCount"     column="kitchen_count"    />
        <result property="balconyCount"     column="balcony_count"    />
        <result property="typicalArea"      column="typical_area"     />
        <result property="layoutImage"      column="layout_image"     />
        <result property="status"           column="status"           />
        <result property="sortOrder"        column="sort_order"       />
        <result property="createBy"         column="create_by"        />
        <result property="createTime"       column="create_time"      />
        <result property="updateBy"         column="update_by"        />
        <result property="updateTime"       column="update_time"      />
        <result property="remark"           column="remark"           />
        <result property="delFlag"          column="del_flag"         />
    </resultMap>

    <sql id="selectHouseTypeVo">
        SELECT
            ht.house_type_id, ht.project_id, p.project_name, ht.house_type_name, ht.house_type_code,
            ht.bedroom_count, ht.livingroom_count, ht.bathroom_count,
            ht.kitchen_count, ht.balcony_count, ht.typical_area,
            ht.layout_image, ht.status, ht.sort_order,
            ht.create_by, ht.create_time, ht.update_by, ht.update_time, ht.remark, ht.del_flag
        FROM hz_house_type ht
        LEFT JOIN hz_project p ON ht.project_id = p.project_id
    </sql>

    <select id="selectHouseTypeList" parameterType="com.ruoyi.system.domain.HzHouseType" resultMap="HzHouseTypeResult">
        <include refid="selectHouseTypeVo"/>
        <where>
            ht.del_flag = '0'
            <if test="projectId != null">
                AND ht.project_id = #{projectId}
            </if>
            <if test="houseTypeName != null and houseTypeName != ''">
                AND ht.house_type_name LIKE CONCAT('%', #{houseTypeName}, '%')
            </if>
            <if test="houseTypeCode != null and houseTypeCode != ''">
                AND ht.house_type_code = #{houseTypeCode}
            </if>
            <if test="bedroomCount != null">
                AND ht.bedroom_count = #{bedroomCount}
            </if>
            <if test="livingroomCount != null">
                AND ht.livingroom_count = #{livingroomCount}
            </if>
            <if test="bathroomCount != null">
                AND ht.bathroom_count = #{bathroomCount}
            </if>
            <if test="status != null and status != ''">
                AND ht.status = #{status}
            </if>
        </where>
        ORDER BY ht.sort_order ASC, ht.create_time DESC
    </select>

</mapper>
