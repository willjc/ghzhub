<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.HzBuildingMapper">

    <resultMap type="com.ruoyi.system.domain.HzBuilding" id="HzBuildingResult">
        <id     property="buildingId"      column="building_id"     />
        <result property="projectId"       column="project_id"      />
        <result property="projectName"     column="project_name"    />
        <result property="buildingName"    column="building_name"   />
        <result property="buildingCode"    column="building_code"   />
        <result property="totalFloors"     column="total_floors"    />
        <result property="totalUnits"      column="total_units"     />
        <result property="totalHouses"     column="total_houses"    />
        <result property="status"          column="status"          />
        <result property="sortOrder"       column="sort_order"      />
        <result property="delFlag"         column="del_flag"        />
        <result property="createBy"        column="create_by"       />
        <result property="createTime"      column="create_time"     />
        <result property="updateBy"        column="update_by"       />
        <result property="updateTime"      column="update_time"     />
        <result property="remark"          column="remark"          />
    </resultMap>

    <sql id="selectBuildingVo">
        SELECT
            b.building_id, b.project_id, b.building_name, b.building_code,
            b.total_floors, b.total_units,
            IFNULL((SELECT COUNT(*) FROM hz_house h WHERE h.building_id = b.building_id AND h.del_flag = '0'), 0) as total_houses,
            b.status, b.sort_order, b.del_flag,
            b.create_by, b.create_time, b.update_by, b.update_time, b.remark,
            p.project_name
        FROM hz_building b
        LEFT JOIN hz_project p ON b.project_id = p.project_id
    </sql>

    <select id="selectBuildingAllocationList" parameterType="com.ruoyi.system.domain.HzBuilding" resultMap="HzBuildingResult">
        <include refid="selectBuildingVo"/>
        <where>
            b.del_flag = '0'
            <if test="projectId != null">
                AND b.project_id = #{projectId}
            </if>
            <if test="buildingName != null and buildingName != ''">
                AND b.building_name LIKE CONCAT('%', #{buildingName}, '%')
            </if>
            <if test="buildingCode != null and buildingCode != ''">
                AND b.building_code LIKE CONCAT('%', #{buildingCode}, '%')
            </if>
            <if test="status != null and status != ''">
                AND b.status = #{status}
            </if>
        </where>
        ORDER BY b.sort_order ASC, b.create_time DESC
    </select>

</mapper>
