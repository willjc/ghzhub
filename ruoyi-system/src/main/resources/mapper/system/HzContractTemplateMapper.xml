<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.HzContractTemplateMapper">

    <resultMap type="HzContractTemplate" id="HzContractTemplateResult">
        <result property="templateId"    column="template_id"    />
        <result property="templateName"    column="template_name"    />
        <result property="templateCode"    column="template_code"    />
        <result property="contractType"    column="contract_type"    />
        <result property="templateContent"    column="template_content"    />
        <result property="paymentCycle"    column="payment_cycle"    />
        <result property="contractDuration"    column="contract_duration"    />
        <result property="depositMonths"    column="deposit_months"    />
        <result property="depositAmount"    column="deposit_amount"    />
        <result property="penaltyRate"    column="penalty_rate"    />
        <result property="penaltyAmount"    column="penalty_amount"    />
        <result property="version"    column="version"    />
        <result property="isDefault"    column="is_default"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTemplateVo">
        select template_id, template_name, template_code, contract_type, template_content,
               payment_cycle, contract_duration, deposit_months, deposit_amount, penalty_rate, penalty_amount,
               version, is_default, status, del_flag, create_by, create_time, update_by, update_time, remark
        from hz_contract_template
    </sql>

    <select id="selectTemplateList" parameterType="HzContractTemplate" resultMap="HzContractTemplateResult">
        <include refid="selectTemplateVo"/>
        <where>
            del_flag = '0'
            <if test="templateName != null and templateName != ''">
                AND template_name like concat('%', #{templateName}, '%')
            </if>
            <if test="templateCode != null and templateCode != ''">
                AND template_code = #{templateCode}
            </if>
            <if test="contractType != null and contractType != ''">
                AND contract_type = #{contractType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by contract_type, create_time desc
    </select>

    <select id="selectTemplateByType" parameterType="String" resultMap="HzContractTemplateResult">
        <include refid="selectTemplateVo"/>
        where del_flag = '0' and contract_type = #{contractType} and status = '0'
        limit 1
    </select>

</mapper>
